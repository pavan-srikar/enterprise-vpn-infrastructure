{
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "id": 1,
      "title": "Active Peers",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] }
        }
      },
      "targets": [{ "expr": "count(wireguard_latest_handshake_seconds > 0)", "legendFormat": "Active Peers", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "id": 2,
      "title": "Total Peers Configured",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": 0 }] }
        }
      },
      "targets": [{ "expr": "count(wireguard_latest_handshake_seconds)", "legendFormat": "Total Peers", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "id": 3,
      "title": "Total Data Received",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "fixedColor": "green", "mode": "fixed" } } },
      "targets": [{ "expr": "sum(wireguard_received_bytes_total)", "legendFormat": "Received", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "id": 4,
      "title": "Total Data Sent",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "fixedColor": "blue", "mode": "fixed" } } },
      "targets": [{ "expr": "sum(wireguard_sent_bytes_total)", "legendFormat": "Sent", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "id": 5,
      "title": "Traffic per Peer — Received (bytes/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "options": { "legend": { "calcs": ["last", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "targets": [{ "expr": "rate(wireguard_received_bytes_total[5m])", "legendFormat": "{{peer_name}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "id": 6,
      "title": "Traffic per Peer — Sent (bytes/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "options": { "legend": { "calcs": ["last", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "targets": [{ "expr": "rate(wireguard_sent_bytes_total[5m])", "legendFormat": "{{peer_name}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "id": 7,
      "title": "Last Handshake Age per Peer",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 12 },
      "options": { "legend": { "calcs": ["last"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 180 }, { "color": "red", "value": 300 }] }
        }
      },
      "targets": [{ "expr": "time() - wireguard_latest_handshake_seconds", "legendFormat": "{{peer_name}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "id": 8,
      "title": "Peer Overview Table",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "options": { "footer": { "show": false } },
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Received" }, "properties": [{ "id": "unit", "value": "bytes" }] },
          { "matcher": { "id": "byName", "options": "Sent" }, "properties": [{ "id": "unit", "value": "bytes" }] }
        ]
      },
      "targets": [
        { "expr": "wireguard_received_bytes_total", "legendFormat": "{{peer_name}}", "instant": true, "datasource": { "type": "prometheus", "uid": "prometheus" }, "refId": "A" },
        { "expr": "wireguard_sent_bytes_total", "legendFormat": "{{peer_name}}", "instant": true, "datasource": { "type": "prometheus", "uid": "prometheus" }, "refId": "B" }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "renameByName": { "Value #A": "Received", "Value #B": "Sent", "peer_name": "Peer", "allowed_ips": "Allowed IPs", "interface": "Interface" } } }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["vpn", "wireguard"],
  "time": { "from": "now-3h", "to": "now" },
  "timezone": "browser",
  "title": "WireGuard VPN Dashboard",
  "uid": "wireguard-vpn",
  "version": 1
}
